<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Recipe Title"
            android:textSize="18sp"
            android:textColor="#1C1B1F"
            android:textColorHint="#79747E"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.01"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etRecipe"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="Paste recipe steps here..."
            android:gravity="top"
            android:inputType="textMultiLine"
            android:padding="16dp"
            android:background="@android:drawable/edit_text"
            android:textSize="15sp"
            android:textColor="#1C1B1F"
            android:textColorHint="#79747E"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.01"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Multiplier"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#49454F"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ToggleButton
                android:id="@+id/btn1x"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:textOn="1x"
                android:textOff="1x"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:background="@drawable/toggle_selected"
                android:textColor="@color/toggle_text"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <ToggleButton
                android:id="@+id/btn2x"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:textOn="2x"
                android:textOff="2x"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:background="@drawable/toggle_selected"
                android:textColor="@color/toggle_text"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:elevation="2dp" />

            <ToggleButton
                android:id="@+id/btn3x"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:textOn="3x"
                android:textOff="3x"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:background="@drawable/toggle_selected"
                android:textColor="@color/toggle_text"
                android:layout_marginStart="8dp"
                android:elevation="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Measurement System"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#49454F"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:paddingTop="8dp"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <ToggleButton
                android:id="@+id/btnUK"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:textOn="UK"
                android:textOff="UK"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:background="@drawable/toggle_selected"
                android:textColor="@color/toggle_text"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <ToggleButton
                android:id="@+id/btnUS"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:textOn="US"
                android:textOff="US"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:background="@drawable/toggle_selected"
                android:textColor="@color/toggle_text"
                android:layout_marginStart="8dp"
                android:elevation="2dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start Cooking"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:backgroundTint="#6750A4"
            android:elevation="4dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save Recipe"
            android:textSize="14sp"
            android:textColor="#6750A4"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:backgroundTint="#E8DEF8"
            android:elevation="2dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLoad"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Load Recipe"
            android:textSize="14sp"
            android:textColor="#49454F"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"
            android:backgroundTint="#E7E0EC"
            android:elevation="2dp" />

    </LinearLayout>

</ScrollView>